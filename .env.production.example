# Production Environment Configuration
# Created: 2026-03-23
# Usage: Copy to .env.production and update values

# Environment
ENVIRONMENT=production
DEBUG=false

# API Security
API_KEY=your-api-key-here
SECRET_KEY=your-secret-key-change-this-immediately

# CORS Settings
ALLOWED_ORIGINS=["https://semptify.example.com","https://api.example.com"]
ALLOW_CREDENTIALS=true
ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]
ALLOW_HEADERS=["Content-Type","Authorization","X-API-Key"]

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Authentication
AUTH_REQUIRED=true
JWT_ALGORITHM=HS256
JWT_EXPIRY=3600

# HTTPS/SSL
HTTPS_ONLY=true
SSL_CERT_PATH=/etc/ssl/certs/semptify.crt
SSL_KEY_PATH=/etc/ssl/private/semptify.key

# Security Headers
HSTS_MAX_AGE=31536000

# Database Security
DB_SSL_MODE=require
DB_CONNECTION_TIMEOUT=10
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=0

# Logging & Monitoring
LOG_LEVEL=INFO
SENTRY_ENABLED=false
SENTRY_DSN=

# Input Validation
MAX_REQUEST_SIZE=10485760
MAX_BATCH_DOCUMENTS=100

# Session Security
SESSION_TIMEOUT=1800
SECURE_COOKIES=true
HTTPONLY_COOKIES=true
SAMESITE_COOKIES=Strict

# IP Whitelisting (optional)
IP_WHITELIST_ENABLED=false
IP_WHITELIST=[]

# Database Connection
DATABASE_URL=postgresql+asyncpg://user:password@db-host:5432/semptify_prod?ssl=require

# Logging
LOG_FILE=/var/log/semptify/production.log
